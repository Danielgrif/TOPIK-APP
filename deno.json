{
  "importMap": "./supabase/functions/import_map.json",
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test --allow-net --allow-env --allow-read supabase/functions/**/*.test.ts",
    "test:watch": "deno test --watch --allow-net --allow-env --allow-read supabase/functions/**/*.test.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "options": {
      "indentWidth": 2,
      "singleQuote": false
    }
  }
}